{
  "name": "aether",
  "version": "1.0.0",
  "description": "Aether – sleek, fast web unblocker / proxy site using Scramjet, Ultraviolet, bare-mux, Wisp, and Fastify.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "fresh-start": "npm install && npm run build && npm start"
  },
  "dependencies": {
    "@fastify/compress": "^8",
    "@fastify/cookie": "^9",
    "@fastify/formbody": "^7",
    "@fastify/static": "^7",
    "fastify": "^5",
    "micromatch": "^4"
  },
  "devDependencies": {
    "concurrently": "^8",
    "vite": "^5",
    "vite-plugin-static-copy": "^1"
  }
}
